# Local Asterisk edge dev harness -- env placeholders (Phase 11, D-09).
#
# NEVER put a real secret in this file (it IS committed). Copy it to `.env`
# (already gitignored by apps/voice/.gitignore's `.env` entry) and fill in
# real local-dev-only values there. Production secrets live in SSM
# (Phase 14) -- this file is local-dev only.

# ARI (Asterisk REST Interface) -- consumed by the standalone telephony
# controller (D-08, a later plan), not by this compose harness directly.
ASTERISK_ARI_URL=http://127.0.0.1:8088
ASTERISK_ARI_USERNAME=klanker
ASTERISK_ARI_PASSWORD=

# SIP softphone credential -- consumed by Asterisk (pjsip.conf) only; never
# passed into the Klanker Python process (D-09).
SOFTPHONE_SIP_PASSWORD=

# The §24 silent answer-gate secrets (D-05). Never placed in LLM context,
# logs, or the transcript ledger (D-05e) -- consumed only by the gate
# matcher in a later plan.
TELEPHONY_ACCESS_PIN=
TELEPHONY_PASSPHRASE_WORDS=
