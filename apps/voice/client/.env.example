# klanker-voice client — public OIDC config (CLNT-08, D-04).
#
# There is NO client secret here on purpose: the voice SPA is a PKCE public
# client (RFC 7636). Every value below is safe to bake into the built
# JavaScript bundle — none of it is a credential. Production values are
# baked in at build time via apps/voice/Dockerfile's client-build stage ARGs
# (defaulted to the values below); copy this file to `.env.local` only if
# you need to override them for local dev against a non-default target.

# OIDC issuer base URL (auth.klankermaker.ai, Phase-3/4 pinned contract).
VITE_OIDC_ISSUER=https://auth.klankermaker.ai/use1/api/oidc

# Public client_id registered on the issuer as an authorization-code+PKCE
# client (no secret — see apps/auth/webapp/src/config/oidc.ts `voice` client).
VITE_OIDC_CLIENT_ID=voice

# Resource-indicator audience the issued access token must carry — matches
# apps/voice/src/klanker_voice/auth.py's DEFAULT_AUDIENCE exactly.
VITE_OIDC_AUDIENCE=https://voice.klankermaker.ai

# This SPA's own callback route. Must be registered as a redirect_uri on the
# 'voice' OIDC client. For local dev against `vite dev` (port 5173), use
# http://localhost:5173/callback instead.
VITE_OIDC_REDIRECT_URI=https://voice.klankermaker.ai/callback
