# Local dev environment — never ships in the image.
.venv/
.env
.python-version

# Python cache/build artifacts.
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/

# Run artifacts (rendered audio, per-run JSON harness output) — never shipped.
artifacts/

# Tests and fixtures — not needed at runtime.
tests/
scripts/
scenarios/

# VCS / editor.
.git/
.gitignore
.DS_Store

# Client (Vite+TS+React SPA) build artifacts — the multi-stage Docker build's
# `client-build` stage runs `npm ci && npm run build` fresh from source; a
# stale host-local dist/ or node_modules/ must never leak into either build
# stage's context (D-03: no committed/carried-over build artifacts).
client/node_modules/
client/dist/
