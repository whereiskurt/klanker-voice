# klanker-voice non-secret infra env (D-06, checked in — NO secrets, NO sso-login lines).
# Load via direnv (`direnv allow infra`) or `source infra/.envrc` manually.
export SITE_LABEL=kmv
export SGUID=6e913c73
export TG_BUCKET_USE1="tf-${SITE_LABEL}-use1-${SGUID}"
export TG_TABLE_USE1="tf-${SITE_LABEL}-use1-${SGUID}"
export AWS_REGION=us-east-1
# site.hcl decrypts .secrets.sops.json at parse time (run_cmd sops --decrypt);
# sops needs ambient AWS creds for kms:Decrypt — profile name is non-secret.
export AWS_PROFILE=klanker-terraform
export TF_VAR_APPLICATION_ACCOUNT_ID=052251888500
export TF_VAR_MANAGEMENT_ACCOUNT_ID=481723467561
# providers append the dash — do not add one here
export TF_VAR_profile_prefix=klanker
export TF_VAR_GITHUB_ORG=whereiskurt
export TF_VAR_SOPS_KMS_KEY_ID=76235c7b-90ba-4ca8-a87d-19870c7c112f
# Module CMKs (secrets/dynamodb/email regional SSM keys) — CI readonly/terragrunt
# roles need kms:Decrypt on these to read SecureStrings during plans.
# alias/kmv-ssm-use1, alias/kmv-dynamodb-ssm-use1, alias/kmv-email-ssm-use1
export TF_VAR_SSM_KMS_KEY_ARNS="arn:aws:kms:us-east-1:052251888500:key/5c9b878b-122c-41b2-acd4-5fe5c83531bb,arn:aws:kms:us-east-1:052251888500:key/d5d6f906-7306-4e67-827d-dd3ce0fc4f66,arn:aws:kms:us-east-1:052251888500:key/60b07929-6a9d-4518-a392-ca326125836e"
